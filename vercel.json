{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "api/index.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "api/index.ts"
    },
    {
      "source": "/((?!api|assets|static|favicon|robots|sitemap|manifest\\.json|sw\\.js|icon-192\\.png|icon-512\\.png|apple-touch-icon\\.png|screenshot-mobile\\.png|screenshot-desktop\\.png|c557dadad68347b8e26939a56c132027\\.txt|llms\\.txt).*)",
      "destination": "/index.html"
    }
  ]
}